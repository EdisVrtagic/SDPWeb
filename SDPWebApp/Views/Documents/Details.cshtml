@model SDPWebApp.Models.Document

@{
    ViewData["Title"] = "Review";
    bool missingItems = Model.ValidationIssues.Any(i => i.IssueType == "Missing Items");
}
<head>
    <link rel="stylesheet" type="text/css" href="~/css/revmain.css" />
</head>
<div class="container mt-4">
    <form asp-action="Edit" method="post" id="reviewForm">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>
                <i class="bi @(Model.Type == DocumentType.Invoice ? "bi-receipt" : "bi-cart-check")"></i>
                @Model.Type: @Model.FileName
            </h2>
            <span class="badge @(Model.Status == DocumentStatus.NeedsReview ? "bg-warning text-dark" : "bg-success") fs-5">
                @Model.Status
            </span>
        </div>
        @if (Model.ValidationIssues.Any())
        {
            <div id="validationAlert" class="alert shadow-sm border-0">
                <h5><i class='bx bx-x-circle'></i> Errors:</h5>
                <ul class="mb-0">
                    @foreach (var issue in Model.ValidationIssues)
                    {
                        <li><strong class="text-white">@issue.IssueType:</strong> @issue.ErrorMessage</li>
                    }
                </ul>
            </div>
        }
        <div class="row">
            <div class="col-md-5">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">Document information</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Supplier</label>
                            <input asp-for="SupplierName" id="SupplierName"
                                   class="form-control @(Model.SupplierName != null && Model.SupplierName.Contains("Unknown") ? "is-invalid" : "")"
                                   oninput="validateForm()" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Document number</label>
                            <input asp-for="DocumentNumber" id="DocumentNumber"
                                   class="form-control @(string.IsNullOrEmpty(Model.DocumentNumber) || Model.DocumentNumber == "Unknown" ? "is-invalid" : "")"
                                   oninput="validateForm()" />
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">Issue Date</label>
                                <input asp-for="IssueDate" type="date" id="IssueDate"
                                       value="@(Model.IssueDate?.ToString("yyyy-MM-dd"))"
                                       class="form-control" oninput="validateForm()" />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Due Date</label>
                                <input asp-for="DueDate" type="date" id="DueDate"
                                       value="@(Model.DueDate?.ToString("yyyy-MM-dd"))"
                                       class="form-control" oninput="validateForm()" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <label class="form-label fw-bold">Tax</label>
                                <input asp-for="TaxAmount" type="number" step="0.01" class="form-control" oninput="validateForm()" />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Total</label>
                                <input asp-for="TotalAmount" type="number" step="0.01" class="form-control fw-bold text-primary" oninput="validateForm()" />
                            </div>
                        </div>
                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" id="btnConfirm" class="btn btn-success btn-lg shadow" disabled>
                                <i class="bi bi-check-circle"></i> Confirm and validate
                            </button>
                            <button form="rejectForm" type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle"></i> Reject the document
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none text-center">
                                <i class="bi bi-arrow-left"></i> Return to list
                            </a>
                        </div>
                        <div id="hintMessage" class="alert alert-warning mt-3 py-2 small text-center d-none" style="color: var(--color-box) !important;">
                            <i class="bi bi-info-circle"></i>
                            <span id="hintText"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-7">
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <span class="fw-bold">Items</span>
                        
                        @if (missingItems)
                        {
                            <button type="button" class="btn btn-sm btn-primary" onclick="addRow()">
                                <i class="bi bi-plus-lg"></i> Add item
                            </button>
                        }
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Description</th>
                                        <th class="text-center" style="width: 15%">Quantity</th>
                                        <th class="text-end" style="width: 20%">Price</th>
                                        <th class="text-end" style="width: 20%">Total</th>
                                    </tr>
                                </thead>
                                <tbody id="itemsBody">
                                    @foreach (var item in Model.LineItems)
                                    {
                                        <tr class="existing-item">
                                            <td>@item.Description</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                                            <td class="text-end fw-bold">@item.LineTotal.ToString("N2")</td>
                                        </tr>
                                    }
                                    @if (!Model.LineItems.Any())
                                    {
                                        <tr id="noItemsRow">
                                            <td colspan="4" class="text-center text-white-50 py-4">
                                                There are no items. @(missingItems ? "Click 'Add item' for manual entry." : "")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <form id="rejectForm" asp-action="UpdateStatus" method="post" style="display:none;">
        <input type="hidden" name="id" value="@Model.Id" />
        <input type="hidden" name="status" value="Rejected" />
    </form>
</div>
<script src="/js/ValidScript.js" asp-append-version="true"></script>